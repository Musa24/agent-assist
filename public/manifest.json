{
  "manifest_version": 3,
  "name": "Insystem",
  "version": "0.1.0",
  "description": "AI-powered assistant for betting customer support agents.",
  "permissions": ["activeTab", "storage", "contextMenus", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
