{
  "name": "agent-assist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Insystem — AI-powered Chrome Extension for betting customer support agents",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build:prod && cd dist && zip -r ../agent-assist.zip ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.9.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
